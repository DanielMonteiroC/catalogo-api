# ============================================
# ARQUIVO DE CONFIGURAÇÃO DE AMBIENTE
# Copie este arquivo para .env e preencha os valores
# ============================================

# Porta da aplicação
PORT=3000

# Ambiente (development | production | test)
NODE_ENV=development

# Chave secreta para geração dos tokens JWT
# Use uma string longa, aleatória e segura em produção!
JWT_SECRET=troque_por_uma_chave_muito_segura_aqui

# Tempo de expiração do token JWT
JWT_EXPIRES_IN=2h

# ---- PostgreSQL (banco relacional - usuários) ----
PG_HOST=localhost
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=sua_senha_aqui
PG_DATABASE=catalogo_usuarios

# ---- MongoDB (banco NoSQL - catálogo) ----
MONGO_URI=mongodb://localhost:27017/catalogo_nosql
